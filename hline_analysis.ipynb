    "from scipy.optimize import curve_fit\n",
    "\n",
    "\n",
    "def gaussian(nu, A, nu0, sigma, c):\n",
    "    return A * np.exp(-(nu - nu0) ** 2 / (2 * sigma ** 2)) + c\n",
