    "    # TODO: open the FITS file, read the frequency axis from the primary HDU\n",
    "    # and the TIME and PSD columns from the SPECTRUM extension.\n",
    "    pass\n",
    "\n",
    "\n",
    "def flag_RFI_win(psd, winsize, n_MAD=3):\n",
    "    \"\"\"Sliding-window RFI flagger using median + median absolute deviation.\n",
    "\n",
    "    Walks a window of size `winsize` across `psd`. In each window, computes the\n",
    "    local median and MAD, then replaces any sample whose distance from the median\n",
    "    exceeds n_MAD * MAD with NaN. Window-based median + MAD are robust to the\n",
    "    spikes themselves, which is why this works better than a single global cut.\n",
    "\n",
    "    Returns the cleaned spectrum (same shape as input, flagged samples set to NaN).\n",
    "    \"\"\"\n",
    "    # TODO: walk a window across psd; in each window compute median + MAD and\n",
    "    # NaN out outliers more than n_MAD * MAD from the local median.\n",
    "    pass\n",
    "\n",
    "\n",
    "def subtract_baseline(freq, psd, deg=90):\n",
    "    \"\"\"Fit a high-order polynomial to the NaN-aware spectrum and subtract it.\n",
    "\n",
    "    Used to remove the residual continuum / bandpass shape that survives RFI\n",
    "    flagging. Returns psd minus the polynomial evaluated on `freq`.\n",
    "    \"\"\"\n",
    "    # TODO: use np.polyfit on the non-NaN samples, evaluate the polynomial on\n",
    "    # `freq`, and subtract from `psd`.\n",
    "    pass"
