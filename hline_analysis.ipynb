    "    time : ndarray, shape (n_spectra,)\n",
    "        UNIX timestamps from the SPECTRUM extension, one per integration.\n",
    "    psd : ndarray, shape (n_spectra, nfft)\n",
    "        Linear-power spectrum per integration, from the SPECTRUM extension.\n",
